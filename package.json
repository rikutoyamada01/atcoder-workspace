{
  "name": "atcoder-workspace",
  "version": "1.4.3",
  "description": "Competitive Programming Workspace for AtCoder",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup-monaco.js",
    "test": "jest",
    "lint": "eslint src tests scripts",
    "format": "prettier --write \"src/**/*.{js,css}\" \"tests/**/*.js\" \"scripts/**/*.js\" \"*.json\" \"README.md\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\" \"tests/**/*.js\" \"scripts/**/*.js\" \"*.json\" \"README.md\"",
    "build": "node scripts/build-release.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.9.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "monaco-editor": "^0.39.0",
    "prettier": "^3.2.5"
  }
}
